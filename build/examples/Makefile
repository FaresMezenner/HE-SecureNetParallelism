	cd /home/lf_mezenner_udst_edu_qa/secure-parallel-training/HE-SecureNet/build && $(MAKE) $(MAKESILENT) -f examples/CMakeFiles/softmax_test_exe.dir/build.make examples/CMakeFiles/softmax_test_exe.dir/softmax_test.cpp.o
.PHONY : softmax_test.cpp.o

softmax_test.i: softmax_test.cpp.i
.PHONY : softmax_test.i

# target to preprocess a source file
softmax_test.cpp.i:
	cd /home/lf_mezenner_udst_edu_qa/secure-parallel-training/HE-SecureNet/build && $(MAKE) $(MAKESILENT) -f examples/CMakeFiles/softmax_test_exe.dir/build.make examples/CMakeFiles/softmax_test_exe.dir/softmax_test.cpp.i
.PHONY : softmax_test.cpp.i

softmax_test.s: softmax_test.cpp.s
.PHONY : softmax_test.s

# target to generate assembly for a file
softmax_test.cpp.s:
